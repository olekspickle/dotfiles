{
    "$schema": "https://opencode.ai/config.json",
    "theme": "opencode",

    "provider": {
        "llama.cpp": {
            "name": "llama.cpp-server",
            "npm": "@ai-sdk/openai-compatible",
            "options": { "baseURL": "http://127.0.0.1:8080/v1" },
            "models": {
                "qwen3-coder:a3b": {
                    "name": "qwen2.5-coder:3b",
                    "limit": { "context": 128000, "output": 65536 }
                }
            }
        }
    },

    "disabled_providers": [
        "openai",
        "anthropic",
        "gemini"
    ],

    "tools": {
        "bash": true,
        "read": true,
        "edit": true,
        "write": true
    },

    "permission": {
        "bash": {
            "*": "ask",
            "git status": "allow",
            "git diff": "allow",
            "ls": "allow",
            "pwd": "allow",
            "rm *": "deny",
            "curl *": "deny",
            "wget *": "deny"
        },
        "edit": "ask",
        "write": "ask"
    },

    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 8000
    },

    "tui": {
        "scroll_speed": 3,
        "diff_style": "auto"
    }
}
