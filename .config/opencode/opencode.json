{
    "$schema": "https://opencode.ai/config.json",
    "theme": "system",

    "disabled_providers": [
        "openai",
        "gemini"
    ],

    "tools": {
        "bash": true,
        "read": true,
        "edit": true,
        "write": true
    },

    "permission": {
        "edit": "ask",
        "write": "ask",
        "bash": {
            "*": "ask",
            "git status": "allow",
            "git diff": "allow",
            "ls": "allow",
            "pwd": "allow",
            "rm *": "deny",
            "curl *": "deny",
            "wget *": "deny"
        }
    },

    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 8000
    },

    "tui": {
        "scroll_speed": 3,
        "diff_style": "auto"
    }
}
